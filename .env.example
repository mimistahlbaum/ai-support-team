# ===== Required (Discord) =====
DISCORD_GUILD_ID=

SCOUT_BOT_TOKEN=
SCOUT_CLIENT_ID=

SPARK_BOT_TOKEN=
SPARK_CLIENT_ID=

FORGE_BOT_TOKEN=
FORGE_CLIENT_ID=

MIRROR_BOT_TOKEN=
MIRROR_CLIENT_ID=

COORDINATOR_BOT_TOKEN=
COORDINATOR_CLIENT_ID=

# ===== Required (External APIs) =====
GROQ_API_KEY=
TAVILY_API_KEY=
NOTION_KEY=

# ===== Required (Supabase) =====
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ===== Optional =====
# Optional role granted access to task channels.
TASK_ADMIN_ROLE_ID=

# Render provides PORT automatically. Local default is 10000.
PORT=10000

# ===== Optional (Health monitoring / Alerts) =====
# Discord incoming webhook URL for unhealthy/recovery/crash alerts.
DISCORD_ALERT_WEBHOOK_URL=
# Maximum allowed stale time for healthy internal heartbeat (default: 180000).
HEALTHCHECK_MAX_STALE_MS=180000
# Health monitor loop interval (default: 60000).
HEALTHCHECK_INTERVAL_MS=60000
# Cooldown to suppress repeated alerts for the same ongoing incident (default: 300000).
ALERT_COOLDOWN_MS=300000
