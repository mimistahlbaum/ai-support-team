# ===== Required (Discord) =====
DISCORD_GUILD_ID=

COORDINATOR_BOT_TOKEN=
COORDINATOR_CLIENT_ID=

# ===== Deprecated (no longer needed — agents now post via Discord Webhook) =====
# SCOUT_BOT_TOKEN=
# SCOUT_CLIENT_ID=
# SPARK_BOT_TOKEN=
# SPARK_CLIENT_ID=
# FORGE_BOT_TOKEN=
# FORGE_CLIENT_ID=
# MIRROR_BOT_TOKEN=
# MIRROR_CLIENT_ID=

# ===== Required (External APIs) =====
GROQ_API_KEY=
TAVILY_API_KEY=
NOTION_KEY=

# ===== Required (Supabase) =====
SUPABASE_URL=
# Service role key (bypasses RLS — keep secret, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# ===== Optional =====
# Optional role granted access to task channels.
TASK_ADMIN_ROLE_ID=

# OpenAI API key — optional. If set, used as LLM fallback when Groq is unavailable.
OPENAI_API_KEY=

# Render provides PORT automatically. Local default is 10000.
PORT=10000

# ===== Optional (Health monitoring / Alerts) =====
# Startup grace period before /health can return 503 (default: 90000 = 90s).
# Increase if the bot takes longer than 90s to connect to Discord on cold start.
STARTUP_GRACE_MS=90000
# Discord incoming webhook URL for unhealthy/recovery/crash alerts.
DISCORD_ALERT_WEBHOOK_URL=
# Maximum allowed stale time for healthy internal heartbeat (default: 180000).
HEALTHCHECK_MAX_STALE_MS=180000
# Health monitor loop interval (default: 60000).
HEALTHCHECK_INTERVAL_MS=60000
# Cooldown to suppress repeated alerts for the same ongoing incident (default: 300000).
ALERT_COOLDOWN_MS=300000

# ===== Google API (OAuth2) =====
# 初回セットアップは docs/google-oauth-setup.md を参照。
# Drive / Gmail / Calendar で共通の OAuth2 認証情報を使用します。
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Google Drive: 保存先フォルダ ID（URL の /folders/<ID> の部分）
GOOGLE_DRIVE_FOLDER_ID=

# Drive に自動保存するエージェントロール（カンマ区切り。デフォルト: Forge のみ）
# 例: DRIVE_SAVE_ROLES=Forge,Scribe,Admin
DRIVE_SAVE_ROLES=

# Google Calendar: 対象カレンダー ID（省略時は 'primary'）
GOOGLE_CALENDAR_ID=

# ===== Proactive Scheduler =====
# 日次チェックインを送るDiscordチャンネルID（未設定ならスケジューラーOFF）
PROACTIVE_CHANNEL_ID=
# 通知間隔 ms（デフォルト: 86400000 = 24h）
PROACTIVE_INTERVAL_MS=86400000
# カレンダーの先読み日数（デフォルト: 7）
PROACTIVE_CALENDAR_DAYS=7
# 締切警告の日数（デフォルト: 3日前から通知）
PROACTIVE_DEADLINE_WARN_DAYS=3
# 週次レポートを送信するか（デフォルト: true）
PROACTIVE_WEEKLY_REPORT=true
# 公募・展覧会情報の収集キーワード（カンマ区切り。未設定で無効）
# 例: PROACTIVE_SCOUT_KEYWORDS=現代アート 公募,アーティスト 助成金,展覧会 募集
PROACTIVE_SCOUT_KEYWORDS=

# ===== Notion タスクログ =====
# タスク完了時にログを保存する Notion データベース ID（未設定で無効）
# 必須: タイトル列（type: title、名前は何でも可 — 自動検出）
# 任意: Status(select), TaskType(select), CompletedAt(date), DueDate(date) ← 存在する列のみ書き込み
NOTION_TASKS_DB_ID=

# クリエイティブ系タスク完了時に実績を追記するポートフォリオ Notion ページ ID（未設定で無効）
# 対象タスク種別: grant / exhibition / statement / writing
NOTION_PORTFOLIO_PAGE_ID=

# ===== Grant Scout =====
# 公募スカウトを有効化（true で有効）
GRANT_SCOUT_ENABLED=
# スカウト結果を送信する Discord チャンネル ID（未設定で無効）
GRANT_SCOUT_CHANNEL_ID=
# 見つけた公募を自動で /grant list に追加するか（true で有効）
GRANT_AUTO_TRACK=
# デフォルト検索クエリに追加するカスタムキーワード（カンマ区切り。未設定でデフォルトのみ使用）
# 例: GRANT_EXTRA_QUERIES=ballet grant 2026,contemporary dance funding
GRANT_EXTRA_QUERIES=

# ===== Weekly Scout (助成金・奨学金・Adelaide EOI) =====
# Adelaide EOI スキャンを有効化（GRANT_SCOUT_CHANNEL_ID または PROACTIVE_CHANNEL_ID を使用）
ADELAIDE_EOI_SCOUT_ENABLED=
# Artist-in-Residency スカウト（AU/JP/NZ/EU/CA）を有効化
RESIDENCY_SCOUT_ENABLED=
# 週次スカウトの実行間隔 ms（未設定で毎週月曜9時に実行）
# WEEKLY_SCOUT_INTERVAL_MS=604800000
# 実行曜日 0=日 1=月 2=火 3=水 4=木 5=金 6=土（デフォルト: 1）
# WEEKLY_SCOUT_DAY=1
# 実行時刻 0-23（デフォルト: 9）
# WEEKLY_SCOUT_HOUR=9

# ===== Support System =====
# コミュニティサポート用の FAQ / エスカレーションパイプラインを有効化（true で有効）
# デフォルトは無効（本 bot は個人アシスタント用途のため）
SUPPORT_PIPELINE_ENABLED=
# Escalated support cases are posted to this channel (optional; leave blank to disable)
SUPPORT_ESCALATION_CHANNEL_ID=
# Role to ping when a case is escalated (optional; leave blank to disable)
SUPPORT_ESCALATION_PING_ROLE_ID=

# ===== Calendar Task Scout =====
# カレンダー予定から準備タスクを自動提案するか（true で有効）
CALENDAR_TASK_SCOUT_ENABLED=
# スカウトが先読みする日数（デフォルト: 14）
CALENDAR_SCOUT_LOOKAHEAD_DAYS=14
# スカウトが提案する最小先行日数（デフォルト: 2）
CALENDAR_SCOUT_MIN_DAYS=2

# ===== Channel Organizer =====
# 完了タスクチャンネルを自動アーカイブするか（true で有効）
CHANNEL_ORGANIZER_ENABLED=
# アーカイブカテゴリ名（デフォルト: 📦 アーカイブ）
CHANNEL_ARCHIVE_CATEGORY=
# 完了チャンネルをアーカイブするまでの日数（デフォルト: 30）
CHANNEL_PRUNE_AFTER_DAYS=

# ===== Proactive Scheduler — 送信時刻 =====
# 日次通知の送信時刻（HH:MM 形式、JSTまたはシステムTZ。未設定で interval ベース）
PROACTIVE_NOTIFY_AT=

# ===== Unpaywall (Grant Scout 補助) =====
# 論文フルテキスト取得に使用するメールアドレス（未設定で無効）
UNPAYWALL_EMAIL=

# ===== デバッグ =====
# アクション実行の詳細ログを有効化（true にすると action-executor / execute-run が verbose になる）
DEBUG_ACTIONS=
# Supabase タスクメモリ保存のタイミングログ（true で有効）
DEBUG_SAVE=
