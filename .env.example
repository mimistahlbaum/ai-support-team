# AI Support Team environment template
# Copy to .env and fill required values.

# ===== Required: Discord setup =====
# Target Discord server (guild) ID.
DISCORD_GUILD_ID=

# Scout agent bot credentials.
SCOUT_BOT_TOKEN=
SCOUT_CLIENT_ID=

# Spark agent bot credentials.
SPARK_BOT_TOKEN=
SPARK_CLIENT_ID=

# Forge agent bot credentials.
FORGE_BOT_TOKEN=
FORGE_CLIENT_ID=

# Mirror agent bot credentials.
MIRROR_BOT_TOKEN=
MIRROR_CLIENT_ID=

# Coordinator agent bot credentials.
COORDINATOR_BOT_TOKEN=
COORDINATOR_CLIENT_ID=

# ===== Required: External APIs =====
GROQ_API_KEY=
TAVILY_API_KEY=
NOTION_KEY=

# ===== Required: Supabase storage =====
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ===== Optional: Access control =====
# Role ID granted extra access to task channels.
TASK_ADMIN_ROLE_ID=

# ===== Optional: Runtime =====
# Most platforms inject PORT automatically. Local default is 10000.
PORT=10000

# ===== Optional: Health monitoring & alerts =====
# Discord webhook URL for unhealthy/recovery/crash alerts.
DISCORD_ALERT_WEBHOOK_URL=
# Max allowed stale internal heartbeat in ms (default: 180000).
HEALTHCHECK_MAX_STALE_MS=180000
# Health monitor loop interval in ms (default: 60000).
HEALTHCHECK_INTERVAL_MS=60000
# Minimum interval between repeated alerts in ms (default: 300000).
ALERT_COOLDOWN_MS=300000
